# Normalize line endings: store LF in the repo, check out platform-native.
* text=auto

# Force LF in shell scripts and config that some tools refuse to read with CRLF.
*.sh           text eol=lf
*.py           text eol=lf
*.toml         text eol=lf
*.yaml         text eol=lf
*.yml          text eol=lf
*.json         text eol=lf

# Binary blobs — never touch.
*.png          binary
*.jpg          binary
*.jpeg         binary
*.tif          binary
*.tiff         binary
*.bmp          binary
*.npy          binary
*.pth          binary
*.zip          binary
*.ico          binary
